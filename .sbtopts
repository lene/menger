# sbt options (version controlled, affects both local and CI builds)
# See https://www.scala-sbt.org/1.x/docs/Command-Line-Reference.html

# Disable log4j JMX to prevent cgroup detection errors in Docker/CI
# Fixes: "Could not reconfigure JMX java.lang.NullPointerException: Cannot invoke CgroupInfo.getMountPoint()"
-J-Dlog4j2.disableJmx=true

# Suppress Java 21 warnings for Scala 3.7.4 and native libraries (libGDX, LWJGL)
-J--add-opens=java.base/java.lang=ALL-UNNAMED
-J--add-opens=java.base/java.nio=ALL-UNNAMED
-J--add-opens=java.base/sun.nio.ch=ALL-UNNAMED
-J--enable-native-access=ALL-UNNAMED
-J-Djdk.internal.lambda.disableEagerInitialization=true

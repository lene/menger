#!/bin/sh
# Fast pre-commit (Sprint 28.2): hygiene and policy only, target <5 s.
# Never compiles, never runs tests — the tiered pre-push hook is the
# authoritative quality gate (compile, tests, scalafix, coverage, integration).

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT" || exit 1

STATUS=0

echo "=== pre-commit: fast policy checks ==="

./standards/hooks/check-branch.sh || STATUS=1
./standards/hooks/check-staged-hygiene.sh || STATUS=1
./scripts/check-version-consistency.sh || STATUS=1
./scripts/check-standards-drift.sh --local || STATUS=1

if [ $STATUS -gt 0 ]; then
    echo "pre-commit checks failed — nothing was compiled; fix and retry." >&2
fi
exit $STATUS

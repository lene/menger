# Two-Spheres Caustics Test Scene (pbrt-v4) — Sprint 33 multi-object reference twin.
#
# Two glass spheres side by side, each casting its own caustic on the shared floor —
# exercises the per-instance / merged-target photon emission (P7) that the single-sphere
# canonical scene cannot. Physical twin of examples.dsl.TwoSpheres:
#   Spheres: centers (-1.3,0,0) and (1.3,0,0), radius 0.8, dielectric IOR 1.5
#   Floor:   Y = -2.0, diffuse reflectance 0.8
#   Light:   point (0,10,0), rgb I 500  (radiant intensity, W/sr)
#   Camera:  position (0,4,5) looking at (0,-1,0)
#   Film:    default 800x600 (render script overrides for the gated 400x300 variant)
#
# FOV note: menger's OptiX camera renders at a fixed 45 deg HORIZONTAL fov
# (io.github.lene.optix.CameraState). pbrt applies fov to the narrower image axis (vertical at
# 4:3), so the faithful twin uses the vertical equivalent: 2*atan(tan(22.5)/(4/3)) = 34.516 deg.
#
# pbrt-v4 note: no WorldEnd directive (world block ends at EOF).
# Render via scripts/caustics-validation/render-pbrt-references.sh (never by hooks).

Film "rgb"
    "string filename" "two-spheres.exr"
    "integer xresolution" 800
    "integer yresolution" 600

Scale -1 1 1
LookAt 0 4 5
       0 -1 0
       0 1 0

Camera "perspective"
    "float fov" 34.516

Sampler "pmj02bn"
    "integer pixelsamples" 256

Integrator "sppm"
    "integer maxdepth" 32
    "integer photonsperiteration" 100000

WorldBegin

LightSource "point"
    "point3 from" [ 0 10 0 ]
    "rgb I" [ 500 500 500 ]

# Left glass sphere (IOR 1.5)
AttributeBegin
    Material "dielectric"
        "float eta" 1.5
    Translate -1.3 0 0
    Shape "sphere"
        "float radius" 0.8
AttributeEnd

# Right glass sphere (IOR 1.5)
AttributeBegin
    Material "dielectric"
        "float eta" 1.5
    Translate 1.3 0 0
    Shape "sphere"
        "float radius" 0.8
AttributeEnd

# Floor plane at Y = -2
AttributeBegin
    Material "diffuse"
        "rgb reflectance" [ 0.8 0.8 0.8 ]
    Translate 0 -2 0
    Shape "trianglemesh"
        "integer indices" [ 0 1 2 0 2 3 ]
        "point3 P" [ -10 0 -10
                      10 0 -10
                      10 0  10
                     -10 0  10 ]
AttributeEnd
